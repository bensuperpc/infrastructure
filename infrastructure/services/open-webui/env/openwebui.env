# Database configuration
DATABASE_URL=postgresql://postgres:securepassword123@openwebui-postgres:5432/openwebui
DATABASE_POOL_SIZE=20
DATABASE_POOL_MAX_OVERFLOW=10
DATABASE_POOL_TIMEOUT=30
